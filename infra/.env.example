# Copy to .env (next to docker-compose.dev.yml) and adjust.
# Do NOT commit your .env — it is gitignored.

# === Postgres ===
POSTGRES_USER=ailife
POSTGRES_PASSWORD=ailife
POSTGRES_DB=ailife
POSTGRES_PORT=5432

# === MinIO ===
MINIO_ROOT_USER=ailife
MINIO_ROOT_PASSWORD=ailife-secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# === Radicale (CalDAV) ===
RADICALE_PORT=5232

# === LLM gateway (used in PR3) =========================================
# Profiles documented in the plan §5.2.
#
# --- dev / mock ---
LLM_PROVIDER=mock
LLM_DEFAULT_MODEL=mock-large
LLM_FAST_MODEL=mock-fast
LLM_VISION_MODEL=mock-vision
LLM_EMBEDDING_PROVIDER=mock

# --- cloud Anthropic ---
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-...
# LLM_BASE_URL=https://api.anthropic.com         # optional, this is the default
# LLM_DEFAULT_MODEL=claude-opus-4-7
# LLM_FAST_MODEL=claude-haiku-4-5
# LLM_VISION_MODEL=claude-opus-4-7
# LLM_ANTHROPIC_VERSION=2023-06-01               # optional, header pin
# LLM_MAX_TOKENS=4096                            # optional, fallback when callers omit
# Anthropic has no embeddings endpoint — run a second gateway with
# LLM_PROVIDER=openai-compatible for the embedding channel.

# --- cloud DeepSeek (OpenAI-compatible) ---
# LLM_PROVIDER=openai-compatible
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_DEFAULT_MODEL=deepseek-chat
# LLM_EMBEDDING_MODEL=...                        # optional, DeepSeek has no embeddings; use Ollama side-car

# --- local Ollama (Mac Studio) — free baseline for tests + dev ---
# LLM_PROVIDER=openai-compatible
# LLM_BASE_URL=http://ollama:11434/v1            # required; LLM_API_KEY optional (Ollama ignores Authorization)
# LLM_DEFAULT_MODEL=qwen2.5:72b-instruct
# LLM_FAST_MODEL=qwen2.5:7b-instruct
# LLM_VISION_MODEL=qwen2.5-vl:32b
# LLM_EMBEDDING_MODEL=bge-m3

# === profile-service ===
PROFILE_SERVICE_PORT=8082
PROFILE_DB_URL=jdbc:postgresql://localhost:5432/ailife
PROFILE_DB_USER=ailife
PROFILE_DB_PASSWORD=ailife

# === llm-gateway ===
LLM_GATEWAY_PORT=8081
# Langfuse LLM tracing — off by default; flip on in staging/prod with a project key pair.
LANGFUSE_ENABLED=false
# LANGFUSE_BASE_URL=https://cloud.langfuse.com   # or a self-hosted instance
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...

# === orchestrator ===
ORCHESTRATOR_PORT=8083
LLM_GATEWAY_URL=http://localhost:8081
# Agent that captures actionable messages matching no domain (GTD inbox catch-all).
# Self-disables to echo if not registered. Empty = echo-only fallback.
ORCHESTRATOR_CATCH_ALL_AGENT=tasks

# === gateway-telegram ===
GATEWAY_PORT=8080
GATEWAY_TELEGRAM_BOT_USERNAME=ai_life_bot
GATEWAY_TELEGRAM_BOT_TOKEN=
GATEWAY_DEFAULT_HOUSEHOLD_NAME=default household
PROFILE_SERVICE_URL=http://localhost:8082
ORCHESTRATOR_URL=http://localhost:8083
# Shared secret on POST /internal/send. Same value goes into INTERNAL_API_TOKEN below.
GATEWAY_INTERNAL_API_TOKEN=

# === notifier-service ===
NOTIFIER_PORT=8084
NOTIFIER_DB_URL=jdbc:postgresql://localhost:5432/ailife
NOTIFIER_DB_USER=ailife
NOTIFIER_DB_PASSWORD=ailife
GATEWAY_TELEGRAM_URL=http://localhost:8080
INTERNAL_API_TOKEN=
# Event bus: notifier consumes notify.requested events from bus.outbox.
EVENT_BUS_CHANNEL=ailife_events

# === calendar-agent ===
CALENDAR_AGENT_PORT=8086
CALENDAR_AGENT_URL=http://calendar-agent:8086
PROFILE_SERVICE_URL=http://profile-service:8082
NOTIFIER_URL=http://notifier-service:8084

# === scheduler-service ===
SCHEDULER_PORT=8085
SCHEDULER_DB_URL=jdbc:postgresql://localhost:5432/ailife
SCHEDULER_DB_USER=ailife
SCHEDULER_DB_PASSWORD=ailife
SCHEDULER_TICK_MILLIS=30000
SCHEDULER_BATCH_SIZE=50

# === mcp-caldav ===
MCP_CALDAV_PORT=8090
MCP_CALDAV_DB_URL=jdbc:postgresql://localhost:5432/ailife
MCP_CALDAV_DB_USER=ailife
MCP_CALDAV_DB_PASSWORD=ailife
CALDAV_URL=http://localhost:5232
CALDAV_USER=
CALDAV_PASSWORD=
CALDAV_DEFAULT_CALENDAR=ours

# === mcp-money-pro-import ===
MCP_MONEY_PRO_IMPORT_PORT=8094
MCP_MONEY_PRO_IMPORT_DB_URL=jdbc:postgresql://localhost:5432/ailife
MCP_MONEY_PRO_IMPORT_DB_USER=ailife
MCP_MONEY_PRO_IMPORT_DB_PASSWORD=ailife
MCP_MONEY_PRO_IMPORT_URL=http://localhost:8094
# Set FINANCE_AGENT_MCP_CLIENT_ENABLED=false to silence the MCP client
# in dev/degraded environments where mcp-money-pro-import is not running.
FINANCE_AGENT_MCP_CLIENT_ENABLED=true

# === mcp-tasks ===
MCP_TASKS_PORT=8095
MCP_TASKS_DB_URL=jdbc:postgresql://localhost:5432/ailife
MCP_TASKS_DB_USER=ailife
MCP_TASKS_DB_PASSWORD=ailife
MCP_TASKS_URL=http://localhost:8095
# weekly.review cron registration (enable_weekly_review tool → scheduler-service)
MCP_TASKS_REVIEW_CRON=0 0 9 * * MON
MCP_TASKS_REVIEW_OWNER_AGENT=tasks
MCP_TASKS_REVIEW_TRIGGER_KIND=weekly.review

# === mcp-ics-import ===
MCP_ICS_IMPORT_PORT=8091
MCP_ICS_IMPORT_DB_URL=jdbc:postgresql://localhost:5432/ailife
MCP_ICS_IMPORT_DB_USER=ailife
MCP_ICS_IMPORT_DB_PASSWORD=ailife
ICS_IMPORT_COLLECTION_PREFIX=external
ICS_IMPORT_MAX_BYTES=5242880

# === mcp-finance ===
MCP_FINANCE_PORT=8092
MCP_FINANCE_DB_URL=jdbc:postgresql://localhost:5432/ailife
MCP_FINANCE_DB_USER=ailife
MCP_FINANCE_DB_PASSWORD=ailife
MCP_FINANCE_URL=http://localhost:8092
SCHEDULER_URL=http://localhost:8085
# Daily 09:00 UTC; finance-agent recomputes the period window at trigger time
# so cron frequency and budget period (week/month/year) are decoupled.
MCP_FINANCE_BUDGET_CRON=0 0 9 * * *
MCP_FINANCE_BUDGET_OWNER_AGENT=finance
MCP_FINANCE_BUDGET_TRIGGER_KIND=budget.alert
MCP_FINANCE_RECURRING_OWNER_AGENT=finance
MCP_FINANCE_RECURRING_TRIGGER_KIND=recurring.due
MCP_FINANCE_TRANSACTION_OWNER_AGENT=finance
MCP_FINANCE_TRANSACTION_TRIGGER_KIND=transaction.uncategorised

# === mcp-media-processing (capability-MCP, no DB) ===
MCP_MEDIA_PROCESSING_PORT=8097
# Reads blob bytes from media-service (MEDIA_SERVICE_URL is defined in the media-service block).
# OCR engine: tesseract (real, native lib bundled in the image) | stub (native-free marker).
MCP_MEDIA_PROCESSING_OCR_ENGINE=tesseract
MCP_MEDIA_PROCESSING_TESS_LANG=rus+eng
# caption (vision) tool calls llm-gateway's vision channel.
LLM_GATEWAY_URL=http://localhost:8081
# Agent-facing base URL — finance-agent's receipt-parser calls POST /internal/caption here (MP-c).
MCP_MEDIA_PROCESSING_URL=http://localhost:8097

# === memory-service ===
MEMORY_PORT=8087
MEMORY_DB_URL=jdbc:postgresql://localhost:5432/ailife
MEMORY_DB_USER=ailife
MEMORY_DB_PASSWORD=ailife
MEMORY_SERVICE_URL=http://localhost:8087
MEMORY_DEFAULT_K=5
MEMORY_MAX_K=50
# Must match both the vector(N) column in 004-memory.yml AND the active
# embedding provider. Stage 5 swap to bge-m3 = bump to 1024 + re-embed.
MEMORY_EMBED_DIM=384
# Orchestrator pre-routing recall
ORCHESTRATOR_MEMORY_ENABLED=true
ORCHESTRATOR_MEMORY_RECALL_K=3

# === media-service ===
MEDIA_PORT=8088
MEDIA_DB_URL=jdbc:postgresql://localhost:5432/ailife
MEDIA_DB_USER=ailife
MEDIA_DB_PASSWORD=ailife
MEDIA_SERVICE_URL=http://localhost:8088
# MinIO connection — creds come from the MinIO infra block above (MINIO_ROOT_USER/PASSWORD).
MINIO_ENDPOINT=http://localhost:9000
MEDIA_BUCKET=ai-life-media
# Hard cap on a single upload, in bytes (10 MiB).
MEDIA_MAX_BYTES=10485760

# === conversation-service ===
CONVERSATION_PORT=8089
CONVERSATION_DB_URL=jdbc:postgresql://localhost:5432/ailife
CONVERSATION_DB_USER=ailife
CONVERSATION_DB_PASSWORD=ailife
CONVERSATION_SERVICE_URL=http://localhost:8089

# === finance-agent ===
FINANCE_AGENT_PORT=8093
FINANCE_AGENT_URL=http://finance-agent:8093
FINANCE_AGENT_MEMORY_RECALL_K=5

# === tasks-agent ===
TASKS_AGENT_PORT=8096
TASKS_AGENT_URL=http://tasks-agent:8096
TASKS_AGENT_MEMORY_RECALL_K=5
# Set TASKS_AGENT_MCP_CLIENT_ENABLED=false to silence the MCP client in
# dev/degraded environments where mcp-tasks is not running.
TASKS_AGENT_MCP_CLIENT_ENABLED=true
