# Copy to .env (next to docker-compose.dev.yml) and adjust.
# Do NOT commit your .env — it is gitignored.

# === Postgres ===
POSTGRES_USER=ailife
POSTGRES_PASSWORD=ailife
POSTGRES_DB=ailife
POSTGRES_PORT=5432

# === MinIO ===
MINIO_ROOT_USER=ailife
MINIO_ROOT_PASSWORD=ailife-secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# === Radicale (CalDAV) ===
RADICALE_PORT=5232

# === LLM gateway (used in PR3) =========================================
# Profiles documented in the plan §5.2.
#
# --- dev / mock ---
LLM_PROVIDER=mock
LLM_DEFAULT_MODEL=mock-large
LLM_FAST_MODEL=mock-fast
LLM_VISION_MODEL=mock-vision
LLM_EMBEDDING_PROVIDER=mock

# --- cloud Anthropic ---
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-...
# LLM_BASE_URL=https://api.anthropic.com         # optional, this is the default
# LLM_DEFAULT_MODEL=claude-opus-4-7
# LLM_FAST_MODEL=claude-haiku-4-5
# LLM_VISION_MODEL=claude-opus-4-7
# LLM_ANTHROPIC_VERSION=2023-06-01               # optional, header pin
# LLM_MAX_TOKENS=4096                            # optional, fallback when callers omit
# Anthropic has no embeddings endpoint — run a second gateway with
# LLM_PROVIDER=openai-compatible for the embedding channel.

# --- cloud DeepSeek (OpenAI-compatible) ---
# LLM_PROVIDER=openai-compatible
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_DEFAULT_MODEL=deepseek-chat
# LLM_EMBEDDING_MODEL=...                        # optional, DeepSeek has no embeddings; use Ollama side-car

# --- local Ollama (Mac Studio) — free baseline for tests + dev ---
# LLM_PROVIDER=openai-compatible
# LLM_BASE_URL=http://ollama:11434/v1            # required; LLM_API_KEY optional (Ollama ignores Authorization)
# LLM_DEFAULT_MODEL=qwen2.5:72b-instruct
# LLM_FAST_MODEL=qwen2.5:7b-instruct
# LLM_VISION_MODEL=qwen2.5-vl:32b
# LLM_EMBEDDING_MODEL=bge-m3

# === profile-service ===
PROFILE_SERVICE_PORT=8082
PROFILE_DB_URL=jdbc:postgresql://localhost:5432/ailife
PROFILE_DB_USER=ailife
PROFILE_DB_PASSWORD=ailife

# === llm-gateway ===
LLM_GATEWAY_PORT=8081
# Langfuse LLM tracing — off by default; flip on in staging/prod with a project key pair.
LANGFUSE_ENABLED=false
# LANGFUSE_BASE_URL=https://cloud.langfuse.com   # or a self-hosted instance
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...

# === orchestrator ===
ORCHESTRATOR_PORT=8083
LLM_GATEWAY_URL=http://localhost:8081
# Agent that captures actionable messages matching no domain (GTD inbox catch-all).
# Self-disables to echo if not registered. Empty = echo-only fallback.
ORCHESTRATOR_CATCH_ALL_AGENT=tasks

# === gateway-telegram ===
GATEWAY_PORT=8080
GATEWAY_TELEGRAM_BOT_USERNAME=ai_life_bot
GATEWAY_TELEGRAM_BOT_TOKEN=
GATEWAY_DEFAULT_HOUSEHOLD_NAME=default household
PROFILE_SERVICE_URL=http://localhost:8082
ORCHESTRATOR_URL=http://localhost:8083
# Shared secret on POST /internal/send. Same value goes into INTERNAL_API_TOKEN below.
GATEWAY_INTERNAL_API_TOKEN=

# === notifier-service ===
NOTIFIER_PORT=8084
NOTIFIER_DB_URL=jdbc:postgresql://localhost:5432/ailife
NOTIFIER_DB_USER=ailife
NOTIFIER_DB_PASSWORD=ailife
GATEWAY_TELEGRAM_URL=http://localhost:8080
INTERNAL_API_TOKEN=
# Event bus: notifier consumes notify.requested events from bus.outbox.
EVENT_BUS_CHANNEL=ailife_events

# === calendar-agent ===
CALENDAR_AGENT_PORT=8086
CALENDAR_AGENT_URL=http://calendar-agent:8086
PROFILE_SERVICE_URL=http://profile-service:8082
NOTIFIER_URL=http://notifier-service:8084

# === scheduler-service ===
SCHEDULER_PORT=8085
SCHEDULER_DB_URL=jdbc:postgresql://localhost:5432/ailife
SCHEDULER_DB_USER=ailife
SCHEDULER_DB_PASSWORD=ailife
SCHEDULER_TICK_MILLIS=30000
SCHEDULER_BATCH_SIZE=50

# === mcp-caldav ===
MCP_CALDAV_PORT=8090
MCP_CALDAV_DB_URL=jdbc:postgresql://localhost:5432/ailife
MCP_CALDAV_DB_USER=ailife
MCP_CALDAV_DB_PASSWORD=ailife
CALDAV_URL=http://localhost:5232
CALDAV_USER=
CALDAV_PASSWORD=
CALDAV_DEFAULT_CALENDAR=ours

# === mcp-money-pro-import ===
MCP_MONEY_PRO_IMPORT_PORT=8094
MCP_MONEY_PRO_IMPORT_DB_URL=jdbc:postgresql://localhost:5432/ailife
MCP_MONEY_PRO_IMPORT_DB_USER=ailife
MCP_MONEY_PRO_IMPORT_DB_PASSWORD=ailife
MCP_MONEY_PRO_IMPORT_URL=http://localhost:8094
# Set FINANCE_AGENT_MCP_CLIENT_ENABLED=false to silence the MCP client
# in dev/degraded environments where mcp-money-pro-import is not running.
FINANCE_AGENT_MCP_CLIENT_ENABLED=true

# === mcp-tasks ===
MCP_TASKS_PORT=8095
MCP_TASKS_DB_URL=jdbc:postgresql://localhost:5432/ailife
MCP_TASKS_DB_USER=ailife
MCP_TASKS_DB_PASSWORD=ailife
MCP_TASKS_URL=http://localhost:8095
# weekly.review cron registration (enable_weekly_review tool → scheduler-service)
MCP_TASKS_REVIEW_CRON=0 0 9 * * MON
MCP_TASKS_REVIEW_OWNER_AGENT=tasks
MCP_TASKS_REVIEW_TRIGGER_KIND=weekly.review

# === mcp-wardrobe ===
MCP_WARDROBE_PORT=8101
MCP_WARDROBE_DB_URL=jdbc:postgresql://localhost:5432/ailife
MCP_WARDROBE_DB_USER=ailife
MCP_WARDROBE_DB_PASSWORD=ailife
MCP_WARDROBE_URL=http://localhost:8101

# === mcp-nutrition ===
MCP_NUTRITION_PORT=8104
MCP_NUTRITION_DB_URL=jdbc:postgresql://localhost:5432/ailife
MCP_NUTRITION_DB_USER=ailife
MCP_NUTRITION_DB_PASSWORD=ailife
MCP_NUTRITION_URL=http://localhost:8104

# === mcp-creator (creator domain-MCP) ===
MCP_CREATOR_PORT=8108
MCP_CREATOR_DB_URL=jdbc:postgresql://localhost:5432/ailife
MCP_CREATOR_DB_USER=ailife
MCP_CREATOR_DB_PASSWORD=ailife
MCP_CREATOR_URL=http://localhost:8108

# === creator-agent ===
CREATOR_AGENT_PORT=8109
CREATOR_AGENT_URL=http://localhost:8109
CREATOR_AGENT_MCP_CLIENT_ENABLED=true
CREATOR_AGENT_MEMORY_RECALL_K=5

# === mcp-ics-import ===
MCP_ICS_IMPORT_PORT=8091
MCP_ICS_IMPORT_DB_URL=jdbc:postgresql://localhost:5432/ailife
MCP_ICS_IMPORT_DB_USER=ailife
MCP_ICS_IMPORT_DB_PASSWORD=ailife
ICS_IMPORT_COLLECTION_PREFIX=external
ICS_IMPORT_MAX_BYTES=5242880

# === mcp-finance ===
MCP_FINANCE_PORT=8092
MCP_FINANCE_DB_URL=jdbc:postgresql://localhost:5432/ailife
MCP_FINANCE_DB_USER=ailife
MCP_FINANCE_DB_PASSWORD=ailife
MCP_FINANCE_URL=http://localhost:8092
SCHEDULER_URL=http://localhost:8085
# Daily 09:00 UTC; finance-agent recomputes the period window at trigger time
# so cron frequency and budget period (week/month/year) are decoupled.
MCP_FINANCE_BUDGET_CRON=0 0 9 * * *
MCP_FINANCE_BUDGET_OWNER_AGENT=finance
MCP_FINANCE_BUDGET_TRIGGER_KIND=budget.alert
MCP_FINANCE_RECURRING_OWNER_AGENT=finance
MCP_FINANCE_RECURRING_TRIGGER_KIND=recurring.due
MCP_FINANCE_TRANSACTION_OWNER_AGENT=finance
MCP_FINANCE_TRANSACTION_TRIGGER_KIND=transaction.uncategorised

# === whisper (ASR sidecar — real STT engine behind mcp-media-processing's transcribe) ===
# Self-hosted OSS, free, no key. Host port 9100 to avoid clashing with MinIO on 9000.
WHISPER_PORT=9100
WHISPER_ASR_ENGINE=faster_whisper
WHISPER_ASR_MODEL=base

# === mcp-media-processing (capability-MCP, no DB) ===
MCP_MEDIA_PROCESSING_PORT=8097
# Reads blob bytes from media-service (MEDIA_SERVICE_URL is defined in the media-service block).
# OCR engine: tesseract (real, native lib bundled in the image) | stub (native-free marker).
MCP_MEDIA_PROCESSING_OCR_ENGINE=tesseract
MCP_MEDIA_PROCESSING_TESS_LANG=rus+eng
# STT engine: whisper (real, calls the ASR sidecar over HTTP) | stub (native-free marker).
MCP_MEDIA_PROCESSING_STT_ENGINE=whisper
WHISPER_ASR_URL=http://localhost:9100
# caption (vision) tool calls llm-gateway's vision channel.
LLM_GATEWAY_URL=http://localhost:8081
# Agent-facing base URL — finance-agent's receipt-parser calls POST /internal/caption here (MP-c).
MCP_MEDIA_PROCESSING_URL=http://localhost:8097

# === searxng (backing meta-search for mcp-web, self-hosted) ===
SEARXNG_PORT=8888
# Change in any real deployment; also referenced by infra/searxng/settings.yml.
SEARXNG_SECRET=ailife-dev-secret-change-me

# === mcp-web (capability-MCP, no DB) ===
MCP_WEB_PORT=8098
# SearXNG base URL the search engine queries (GET /search?format=json).
SEARXNG_URL=http://localhost:8888
MCP_WEB_SEARCH_ENGINE=searxng
MCP_WEB_DEFAULT_LIMIT=8
MCP_WEB_MAX_LIMIT=20
MCP_WEB_FETCH_TIMEOUT_MS=8000
MCP_WEB_FETCH_MAX_CHARS=8000
# transcribe_video (yt-dlp binary bundled in the image). engine: yt-dlp | stub.
MCP_WEB_TRANSCRIPT_ENGINE=yt-dlp
MCP_WEB_TRANSCRIPT_LANGS=en.*,ru.*
MCP_WEB_TRANSCRIPT_TIMEOUT_SEC=60
MCP_WEB_TRANSCRIPT_MAX_CHARS=12000
# Agent-facing base URL — the researcher calls POST /internal/search here (R-c).
MCP_WEB_URL=http://localhost:8098

# === mcp-market-data (capability-MCP, no DB, no backing container) ===
MCP_MARKET_DATA_PORT=8100
# Stooq public HTTPS CSV endpoint (free, no key). source: stooq (default; swappable later).
MARKETDATA_STOOQ_URL=https://stooq.com
MARKETDATA_SOURCE=stooq
# Agent-facing base URL — finance-agent's investment-advisor calls POST /internal/quote here (MD-c).
MARKET_DATA_URL=http://localhost:8100

# === mcp-food-data (capability-MCP, no DB, no backing container) ===
MCP_FOOD_DATA_PORT=8107
# Open Food Facts public HTTPS JSON API (free, no key). source: openfoodfacts (default; swappable later).
FOODDATA_OPEN_FOOD_FACTS_URL=https://world.openfoodfacts.org
FOODDATA_SOURCE=openfoodfacts
# Agent-facing base URL — the nutritionist's basket breakdown calls POST /internal/food-lookup here
# to ground its КБЖУ in precise per-100g facts (FD-c).
MCP_FOOD_DATA_URL=http://localhost:8107

# === mcp-youtube (capability-MCP, no DB, no backing container) ===
MCP_YOUTUBE_PORT=8110
# YouTube Data API v3 (public HTTPS JSON API). source: youtubedata (default; swappable later).
YOUTUBE_API_BASE_URL=https://www.googleapis.com/youtube/v3
# Free-quota API key. Blank → the source returns no hits (graceful soft-fail; no key in CI).
YOUTUBE_API_KEY=
YOUTUBE_MAX_RESULTS=5
YOUTUBE_SOURCE=youtubedata
# Agent-facing base URL — the creator-agent's trend gather calls POST /internal/youtube-trends here (CR-d).
MCP_YOUTUBE_URL=http://localhost:8110

# === mcp-reddit (capability-MCP, no DB, no backing container) ===
MCP_REDDIT_PORT=8111
# Reddit API (listings) + auth host (token). Public HTTPS. source: redditapi (default; swappable later).
REDDIT_API_BASE_URL=https://oauth.reddit.com
REDDIT_AUTH_BASE_URL=https://www.reddit.com
# Free app credentials (client_credentials grant). Blank → the source returns no hits (soft-fail; no creds in CI).
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ai-life/mcp-reddit 0.0.1 (by /u/ai-life)
REDDIT_MAX_RESULTS=5
REDDIT_SOURCE=redditapi
# Agent-facing base URL — the creator-agent's trend gather calls POST /internal/reddit-trends here (CR-d).
MCP_REDDIT_URL=http://localhost:8111

# === mcp-feeds (capability-MCP, no DB, no backing container) ===
MCP_FEEDS_PORT=8112
# RSS/Atom URLs are absolute; Telegram channels read from the t.me/s/ web preview. source: romejsoup (default).
FEEDS_TELEGRAM_BASE_URL=https://t.me
FEEDS_USER_AGENT=ai-life/mcp-feeds 0.0.1 (+https://github.com/vlad94fed)
FEEDS_MAX_RESULTS=5
FEEDS_SOURCE=romejsoup
# Agent-facing base URL — the creator-agent's trend gather calls POST /internal/feed-items here (CR-d).
MCP_FEEDS_URL=http://localhost:8112

# === mcp-image-gen (capability-MCP, no DB) ===
MCP_IMAGE_GEN_PORT=8103
# engine: stub (placeholder PNG, no cost) | local (self-hosted model, e.g. Mac Studio GPU).
IMAGE_GEN_ENGINE=stub
IMAGE_GEN_LOCAL_URL=http://localhost:9200
# Agent-facing base URL — stylist calls POST /internal/generate here (once flows use it).
MCP_IMAGE_GEN_URL=http://localhost:8103

# === memory-service ===
MEMORY_PORT=8087
MEMORY_DB_URL=jdbc:postgresql://localhost:5432/ailife
MEMORY_DB_USER=ailife
MEMORY_DB_PASSWORD=ailife
MEMORY_SERVICE_URL=http://localhost:8087
MEMORY_DEFAULT_K=5
MEMORY_MAX_K=50
# Must match both the vector(N) column in 004-memory.yml AND the active
# embedding provider. Stage 5 swap to bge-m3 = bump to 1024 + re-embed.
MEMORY_EMBED_DIM=384
# Orchestrator pre-routing recall
ORCHESTRATOR_MEMORY_ENABLED=true
ORCHESTRATOR_MEMORY_RECALL_K=3

# === media-service ===
MEDIA_PORT=8088
MEDIA_DB_URL=jdbc:postgresql://localhost:5432/ailife
MEDIA_DB_USER=ailife
MEDIA_DB_PASSWORD=ailife
MEDIA_SERVICE_URL=http://localhost:8088
# MinIO connection — creds come from the MinIO infra block above (MINIO_ROOT_USER/PASSWORD).
MINIO_ENDPOINT=http://localhost:9000
MEDIA_BUCKET=ai-life-media
# Hard cap on a single upload, in bytes (10 MiB).
MEDIA_MAX_BYTES=10485760

# === conversation-service ===
CONVERSATION_PORT=8089
CONVERSATION_DB_URL=jdbc:postgresql://localhost:5432/ailife
CONVERSATION_DB_USER=ailife
CONVERSATION_DB_PASSWORD=ailife
CONVERSATION_SERVICE_URL=http://localhost:8089

# === finance-agent ===
FINANCE_AGENT_PORT=8093
FINANCE_AGENT_URL=http://finance-agent:8093
FINANCE_AGENT_MEMORY_RECALL_K=5

# === tasks-agent ===
TASKS_AGENT_PORT=8096
TASKS_AGENT_URL=http://tasks-agent:8096
TASKS_AGENT_MEMORY_RECALL_K=5
# Set TASKS_AGENT_MCP_CLIENT_ENABLED=false to silence the MCP client in
# dev/degraded environments where mcp-tasks is not running.
TASKS_AGENT_MCP_CLIENT_ENABLED=true

# === researcher-agent ===
RESEARCHER_AGENT_PORT=8099
RESEARCHER_AGENT_URL=http://researcher-agent:8099
RESEARCHER_AGENT_MEMORY_RECALL_K=5
# Cheap-first tuning: hits requested from search, and how many to read in full before synthesis.
RESEARCHER_AGENT_SEARCH_LIMIT=6
RESEARCHER_AGENT_FETCH_TOP_N=3
# Set RESEARCHER_AGENT_MCP_CLIENT_ENABLED=false to silence the MCP client in
# dev/degraded environments where mcp-web is not running.
RESEARCHER_AGENT_MCP_CLIENT_ENABLED=true

# === stylist-agent ===
STYLIST_AGENT_PORT=8102
STYLIST_AGENT_URL=http://stylist-agent:8102
STYLIST_AGENT_MEMORY_RECALL_K=5
# Public base URL for HTML deliverable links (analyse-me / capsule). Defaults to the internal
# media-service; set to a publicly-reachable gateway base so the link opens on any device.
STYLIST_PUBLIC_MEDIA_BASE_URL=http://media-service:8088
# Binds mcp-wardrobe (its data) + mcp-media-processing (vision) + mcp-web (trends).
# Set STYLIST_AGENT_MCP_CLIENT_ENABLED=false to silence the MCP client in
# dev/degraded environments where those MCP servers are not running.
STYLIST_AGENT_MCP_CLIENT_ENABLED=true
# Editorial-board theme (optional) — re-skin the HTML deliverables without a code change.
# Defaults = the locked beige/Oranienbaum aesthetic; uncomment to override.
#STYLIST_THEME_PAPER=#efe7d8
#STYLIST_THEME_INK=#3a352d
#STYLIST_THEME_GOLD=#a98a4e
#STYLIST_THEME_SERIF_FAMILY="Oranienbaum",Georgia,serif
#STYLIST_THEME_SANS_FAMILY="Manrope",sans-serif
#STYLIST_THEME_GOOGLE_FONTS_QUERY=family=Oranienbaum&family=Manrope:wght@300;400;500&display=swap

# === nutritionist-agent ===
NUTRITIONIST_AGENT_PORT=8105
NUTRITIONIST_AGENT_URL=http://nutritionist-agent:8105
NUTRITIONIST_AGENT_MEMORY_RECALL_K=5
# Public base URL for rendered HTML deliverable links (<base>/v1/media/{id}); set to a
# publicly-reachable gateway in a real deployment.
NUTRITIONIST_PUBLIC_MEDIA_BASE_URL=http://media-service:8088
# The ration → recipes inter-agent call (NU-g invokes chef) uses the shared ORCHESTRATOR_URL above.
# Binds mcp-nutrition (its data) + mcp-media-processing (vision) + mcp-web (store lookup).
# Set NUTRITIONIST_AGENT_MCP_CLIENT_ENABLED=false to silence the MCP client in
# dev/degraded environments where those MCP servers are not running.
NUTRITIONIST_AGENT_MCP_CLIENT_ENABLED=true

# === chef-agent ===
CHEF_AGENT_PORT=8106
CHEF_AGENT_URL=http://chef-agent:8106
CHEF_AGENT_MEMORY_RECALL_K=5
# Public base URL for rendered recipe-card links (<base>/v1/media/{id}); set to a
# publicly-reachable gateway in a real deployment.
CHEF_PUBLIC_MEDIA_BASE_URL=http://media-service:8088
# Binds mcp-nutrition (ration/diet context) + mcp-web (recipe search).
# Set CHEF_AGENT_MCP_CLIENT_ENABLED=false to silence the MCP client in
# dev/degraded environments where those MCP servers are not running.
CHEF_AGENT_MCP_CLIENT_ENABLED=true
