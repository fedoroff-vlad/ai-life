# ===========================================================================
# Mac Studio deployment overlay (ai-life 24/7 on Apple Silicon + local Ollama)
# ---------------------------------------------------------------------------
# This is NOT a full env file — it lists only the keys that must CHANGE from
# infra/.env.example for a real Mac/Ollama deployment. Workflow:
#
#   1. cp .env.example .env
#   2. apply the values below into .env (LLM block + the four secrets)
#   3. install + pull models on the host (see "Models to pull" and infra/README)
#   4. docker compose --profile hot up -d      # once LC-1 lands; until then: up -d
#
# Rationale for keeping this a delta (not a second full file): .env.example is
# the single source of the ~200 default keys; duplicating it would drift.
# ===========================================================================

# --- LLM: local Ollama via the OpenAI-compatible provider (free, on-device) ---
# Ollama runs natively on the host (Metal GPU), NOT in a container. From inside
# the compose network the host is reachable as host.docker.internal.
LLM_PROVIDER=openai-compatible
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_API_KEY=
# Chat quality model (ai-life default). Downshifts to _DOWNSHIFT when the coder
# tenant is active (wired in LC-4 model-manager; static 32B until then).
# Qwen3 cutover (RESOLVED 2026-07-13): Qwen3 models "think" by default, which breaks strict-JSON
# skill parsing (IntentRouter, extract skills) and is ~2-3x slower. LLM_SUPPRESS_THINKING below
# turns it off (sends reasoning_effort:none; the /no_think prompt tag does NOT work via Ollama /v1).
# The golden lane was re-validated on qwen3:8b with the flag on (see llm-gateway/README §Golden tests).
# Caveat: the flag is global — it also disables thinking on the DEFAULT synthesis channel. Grounded
# synthesis goldens still pass; if a channel later wants thinking back on, that needs per-channel support.
LLM_DEFAULT_MODEL=qwen3:32b
LLM_DEFAULT_MODEL_DOWNSHIFT=qwen3:14b
LLM_SUPPRESS_THINKING=true
# FAST channel — intent routing + safety gate, called on every message; keep small + thinking OFF.
LLM_FAST_MODEL=qwen3:8b
# Vision — OCR / image captioning (media-processing). Cold-loaded on demand.
LLM_VISION_MODEL=minicpm-v
# Embeddings — memory-service recall. Ollama serves these on the same base URL.
# nomic-embed-text emits 768-dim vectors (vs the mock provider's 384). The two lines
# below MUST move together with this model (see .skills/change-map.yaml embedding-model-dim):
#   - MEMORY_EMBED_DIM=768 makes memory-service's fail-fast dim check expect 768.
#   - LIQUIBASE_CONTEXTS=default,embed-768 activates 091-memory-embed-768.yml so the
#     memory.memories.embedding column is widened vector(384)→vector(768) to match
#     (the `default` token stays so any future base-context changeset still runs).
# Swap this model → re-derive all three (bge-m3 = 1024, a different embed-NNNN context/migration).
LLM_EMBEDDING_PROVIDER=openai-compatible
LLM_EMBEDDING_MODEL=nomic-embed-text
MEMORY_EMBED_DIM=768
LIQUIBASE_CONTEXTS=default,embed-768
LLM_MAX_TOKENS=4096

# --- Secrets that MUST be filled (empty in .env.example) ---
# Telegram bot token — the only externally-exposed entry point. Required.
GATEWAY_TELEGRAM_BOT_TOKEN=
# Shared internal auth between gateway/notifier and the services. Set to one
# long random string, identical in both keys.
GATEWAY_INTERNAL_API_TOKEN=
INTERNAL_API_TOKEN=
# CalDAV (Radicale) credentials for the calendar domain.
CALDAV_USER=
CALDAV_PASSWORD=

# --- Finance MCP client (LC-1 hot/cold split) ---
# finance-agent's aux MCPs (money-pro-import / market-data / chart-render) are COLD — not up
# at boot. Their real flows use HTTP /internal/* passthroughs; the Spring AI MCP-SSE binding to
# them is currently unused, so disable it to avoid a per-connection dial timeout at startup while
# those MCPs are down. Re-enable once LC-3 starts them on demand (or if a ChatClient tool path needs SSE).
FINANCE_AGENT_MCP_CLIENT_ENABLED=false

# --- Supervisor / lifecycle (used from LC-2 onward; harmless earlier) ---
SUPERVISOR_IDLE_TTL_MINUTES=15

# ---------------------------------------------------------------------------
# Models to pull on the host before first boot (one-time, ~40 GB total):
#   ollama pull qwen3:32b            # ai-life chat (default)      ~20 GB
#   ollama pull qwen3:14b            # downshift when coder active ~9.3 GB
#   ollama pull qwen3:8b             # FAST channel (routing)      ~5.2 GB
#   ollama pull minicpm-v            # vision / OCR (on demand)    ~5.5 GB
#   ollama pull nomic-embed-text     # embeddings                  ~0.3 GB
# Optional capability keys (only if you enable those cold agents):
#   YOUTUBE_API_KEY / REDDIT_* (creator sources), etc. — see .env.example.
# ---------------------------------------------------------------------------
