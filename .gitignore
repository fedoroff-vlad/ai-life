# ---- Java / Maven ----
*.class
*.log
*.ctxt
.mtj.tmp/
hs_err_pid*
replay_pid*

# Build output
target/
build/
out/
bin/

# Jar / archive artifacts
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Maven wrapper (we may add it later; ignore generated parts)
.mvn/wrapper/maven-wrapper.jar

# ---- IDE ----
.idea/
*.iml
*.iws
*.ipr
.vscode/
.classpath
.project
.settings/
.factorypath

# ---- OS ----
.DS_Store
Thumbs.db
desktop.ini

# ---- Env / secrets ----
.env
.env.*
!.env.example
!.env.mac.example
*.pem
*.key

# ---- Docker / local data ----
infra/data/
docker-data/

# ---- DB backups (postgres-backup writes here; keep the dir, ignore the dumps) ----
infra/backups/*
!infra/backups/.gitkeep

# ---- Ad-hoc captured outputs (mvn/test/CI logs the user/agent wrote out by hand) ----
# Convention: capture to logs/<descriptive>.log instead of dropping files in repo root.
# See CLAUDE.md §"Test strategy" + logs/README.md for the rationale.
logs/*
!logs/README.md
